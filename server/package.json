{
  "name": "spitwater-erp-server",
  "version": "1.0.0",
  "description": "Spitwater ERP — Node.js/Express backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test:db": "node scripts/test-db.js",
    "test": "jest --testTimeout=30000 --forceExit",
    "test:smoke": "jest --testPathPattern=smoke --testTimeout=30000 --forceExit"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^10.0.4",
    "multer": "^2.0.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "sharp": "^0.34.5",
    "uuid": "^10.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "setupFilesAfterEnv": []
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
