# ============================================================
# Spitwater ERP — Environment Variables
# ============================================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER commit .env to git — it contains secrets
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database — SQL Server 2014 on SERVER006 ──────────────────
# Use your Windows machine name OR IP address for DB_SERVER
# If SQL Server is on the same machine use: localhost
# If SQL Server is on another machine on LAN use: SERVER006
DB_SERVER=SERVER006
DB_PORT=1433
DB_DATABASE=Development_04052026

# Authentication method — choose ONE:
# Option A: SQL Server Authentication (username + password)
DB_USER=sa
DB_PASSWORD=YourSaPasswordHere

# Option B: Windows Authentication (comment out DB_USER/DB_PASSWORD above
# and set DB_WINDOWS_AUTH=true — only works if Node runs as a Windows user
# with SQL Server access)
DB_WINDOWS_AUTH=false

# SSL/Encryption — for local dev use false
# For production SQL Server with proper cert, set to true
DB_ENCRYPT=false
DB_TRUST_CERT=true

# ── JWT ──────────────────────────────────────────────────────
# Generate a strong random secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_MINIMUM_64_CHARS
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS — React dev server ──────────────────────────────────
# Vite default port is 5173
CORS_ORIGIN=http://localhost:5173

# ── Bcrypt ───────────────────────────────────────────────────
# Cost factor — 10 is fine for dev, use 12 for production
BCRYPT_ROUNDS=10

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug
